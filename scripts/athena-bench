#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
bench_parent_root="$repo_root/.athena/bench-dev"
manual_bench_root="$bench_parent_root/manual"

usage() {
  cat <<'EOF'
usage:
  scripts/athena-bench setup
  scripts/athena-bench clear
  scripts/athena-bench retrieval [--spec path] [--keep-dev-db]
  scripts/athena-bench creation [--spec path] [--proposals path] [--keep-dev-db]
  scripts/athena-bench trajectory [--spec path] [--athena-mode off|current] [--keep-workdir] [--keep-dev-db]

defaults:
  creation proposals path: benchmarks/creation/proposals/baseline.json

notes:
  retrieval, creation, and trajectory each initialize isolated dev Athena Dolt state under .athena/bench-dev.
  setup initializes shared manual state under .athena/bench-dev/manual.
  clear removes all state under .athena/bench-dev.
  Benchmark run state clears after run unless --keep-dev-db is set.
  Does not touch tracked dogfood state in .athena/db.
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

clear_dev_state() {
  local root="$1"
  rm -rf "$root"
}

setup_dev_state() {
  local root="$1"
  local db_path="$root/db"
  local dolt_home="$root/.dolt-home-db"
  clear_dev_state "$root"
  mkdir -p "$root"
  ATHENA_DB_PATH="$db_path" ATHENA_DOLT_HOME="$dolt_home" \
    "$repo_root/scripts/athena" latest-state >/dev/null
}

new_bench_root() {
  local label="$1"
  mkdir -p "$bench_parent_root"
  mktemp -d "$bench_parent_root/$label.XXXXXX"
}

run_benchmark() {
  local subcommand="$1"
  shift

  local keep_dev_db="false"
  if [[ "${1:-}" == "--keep-dev-db" ]]; then
    keep_dev_db="true"
    shift
  fi

  local bench_root
  local db_path
  local dolt_home
  bench_root="$(new_bench_root "$subcommand")"
  db_path="$bench_root/db"
  dolt_home="$bench_root/.dolt-home-db"

  if [[ "$subcommand" == "creation" ]]; then
    local saw_proposals="false"
    local arg
    for arg in "$@"; do
      if [[ "$arg" == "--proposals" ]]; then
        saw_proposals="true"
        break
      fi
    done
    setup_dev_state "$bench_root"
    if [[ "$keep_dev_db" != "true" ]]; then
      trap "clear_dev_state '$bench_root'" EXIT INT TERM
    else
      printf 'keeping benchmark state at %s\n' "$bench_root" >&2
    fi
    if [[ "$saw_proposals" != "true" ]]; then
      ATHENA_DB_PATH="$db_path" ATHENA_DOLT_HOME="$dolt_home" \
        cargo run --quiet --bin athena-bench -- \
        "$subcommand" "$@" --proposals benchmarks/creation/proposals/baseline.json
    else
      ATHENA_DB_PATH="$db_path" ATHENA_DOLT_HOME="$dolt_home" \
        cargo run --quiet --bin athena-bench -- "$subcommand" "$@"
    fi
    return
  fi

  setup_dev_state "$bench_root"
  if [[ "$keep_dev_db" != "true" ]]; then
    trap "clear_dev_state '$bench_root'" EXIT INT TERM
  else
    printf 'keeping benchmark state at %s\n' "$bench_root" >&2
  fi
  ATHENA_DB_PATH="$db_path" ATHENA_DOLT_HOME="$dolt_home" \
    ATHENA_BENCH_ROOT="$bench_root" \
    cargo run --quiet --bin athena-bench -- "$subcommand" "$@"
}

command_name="${1:-}"
if [[ -z "$command_name" ]]; then
  usage
  exit 1
fi
shift

case "$command_name" in
  setup)
    setup_dev_state "$manual_bench_root"
    ;;
  clear)
    clear_dev_state "$bench_parent_root"
    ;;
  retrieval|creation|trajectory)
    run_benchmark "$command_name" "$@"
    ;;
  --help|-h|help)
    usage
    ;;
  *)
    die "unknown command: $command_name"
    ;;
esac
