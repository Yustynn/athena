#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

repo_dir="${ATHENA_TRAJECTORY_REPO_DIR:?missing ATHENA_TRAJECTORY_REPO_DIR}"
prompt_file="${ATHENA_TRAJECTORY_STEP_PROMPT_FILE:?missing ATHENA_TRAJECTORY_STEP_PROMPT_FILE}"
message_file="${ATHENA_TRAJECTORY_MESSAGE_FILE:?missing ATHENA_TRAJECTORY_MESSAGE_FILE}"
athena_mode="${ATHENA_TRAJECTORY_ATHENA_MODE:-off}"

prompt="$(cat "$prompt_file")"

case "$athena_mode" in
  off)
    prompt="$prompt

Do not use Athena wrappers, Athena MCP, or Athena memory for this run."
    codex exec --full-auto --color never --cd "$repo_dir" \
      --output-last-message "$message_file" \
      "$prompt"
    ;;
  current)
    prompt="$prompt

Use Athena workflow from $repo_root during this run.
At start of substantive work, set purpose with:
$repo_root/scripts/athena ensure-purpose \"Solve trajectory benchmark step\" \"Implement requested repo change and verify hidden oracle-facing behavior.\"
Use Athena normally after that when it helps orientation or follow-up work."
    codex exec --full-auto --color never --cd "$repo_dir" \
      --add-dir "$repo_root" \
      --output-last-message "$message_file" \
      "$prompt"
    ;;
  *)
    printf 'unknown ATHENA_TRAJECTORY_ATHENA_MODE: %s\n' "$athena_mode" >&2
    exit 1
    ;;
esac
